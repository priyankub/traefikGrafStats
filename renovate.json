{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major dependencies",
      "automerge": false
    }
  ],
  "pip_requirements": {
    "fileMatch": ["(^|/)requirements\\.txt$"]
  },
  "github-actions": {
    "fileMatch": ["(^|/)\\.github/workflows/.+\\.yml$"]
  },
  "dockerfile": {
    "fileMatch": ["(^|/)Dockerfile$"]
  }
}
